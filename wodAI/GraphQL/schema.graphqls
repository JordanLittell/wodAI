type User {
  id: Int!
  sub: String!
  firstName: String
  lastName: String
  email: String!
  age: Int
  gender: Gender
  fitnessLevel: FitnessLevel!
  threadId: String
  goal: String
  weight: WeightMeasurement
  height: HeightMeasurement
}

type WeightMeasurement {
  value: Float!
  unit: Weight!
}

type HeightMeasurement {
  value: Float!
  unit: Height!
}

input WeightInput {
  value: Float!
  unit: Weight!
}

input HeightInput {
  value: Float!
  unit: Height!
}

type Benchmark {
  id: Int!
  userId: Int!
  user: User!
  movement: BenchmarkMovement!
  type: BenchmarkType!
  typeValue: BenchmarkTypeValue!
  weight: Float
  reps: Int
  time: Int
  timeUnit: String
  distance: Float
  distanceUnit: String
  weightUnit: WeightUnit
  createdAt: DateTime!
  updatedAt: DateTime!
}

type MesoCycle {
  id: Int!
  userId: Int!
  user: User!
  name: String!
  description: String
  workoutsPerWeek: Int!
  mesocycleLength: Int!
  primaryFocus: Focus!
  secondaryFocus: Focus
  hasDeloadWeek: Boolean!
  hasTestingWeek: Boolean!
  timePerWorkout: Int!
  status: GenerationStatus!
  error: String
  progress: Float!
  workouts: [Workout!]!
  createdAt: DateTime!
  updatedAt: DateTime!
}

type Workout {
  id: Int!
  name: String!
  description: String!
  userId: Int
  user: User
  trainingPlanId: String
  trainingPlan: TrainingPlan
  mesoCycleId: Int
  mesoCycle: MesoCycle
  status: WorkoutStatus!
  dateScheduled: DateTime
  dateCompleted: DateTime
  order: Int
  exercises: [Exercise!]!
  createdAt: DateTime!
  updatedAt: DateTime!
}

type Wod {
  id: String!
  name: String!
  definition: String!
  createdAt: DateTime
  updatedAt: DateTime
}

type Exercise {
  id: String!
  name: String!
  description: String!
  order: Int!
  type: ExerciseType!
  rounds: Int
  definition: JSON!
  workoutId: Int!
  workout: Workout!
  intervals: [Interval!]!
  sets: [ExerciseSet!]!
  createdAt: DateTime!
  updatedAt: DateTime!
}

type Interval {
  id: Int!
  type: IntervalType!
  time: Int!
  unit: TimeUnit!
  completed: Boolean!
  rest: Int!
  restUnit: TimeUnit!
  exerciseId: String!
  exercise: Exercise!
  createdAt: DateTime!
  updatedAt: DateTime!
}

type ExerciseSet {
  id: String!
  name: String!
  reps: Int!
  weight: Float!
  unit: WeightUnit!
  completed: Boolean!
  rest: Int!
  restUnit: TimeUnit!
  exerciseId: String!
  exercise: Exercise!
  createdAt: DateTime!
  updatedAt: DateTime!
}

type TrainingPlan {
  id: String!
  name: String!
  description: String!
  goal: String!
  threadId: String
  startDate: DateTime!
  endDate: DateTime
  isActive: Boolean!
  userId: Int
  user: User
  creatorId: Int!
  workouts: [Workout!]!
  createdAt: DateTime!
  updatedAt: DateTime!
}

enum Gender {
  male
  female
}

enum FitnessLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ELITE
  PRO
}

enum Weight {
  lbs
  kg
}

enum Height {
  inches
  meters
}

