enum BenchmarkType {
  ONE_RM
  THREE_RM
  FIVE_RM
  AMRAP
  FOR_TIME
  MAX_TIME
  MAX_DISTANCE
  MAX_WEIGHT
}

enum BenchmarkTypeValue {
  WEIGHT
  REPS
  TIME
  DISTANCE
}

enum WeightUnit {
  POUND
  KILOGRAM
}

enum Focus {
  STRENGTH
  HYPERTROPHY
  ENDURANCE
  POWER
  SPEED
  AGILITY
  FLEXIBILITY
  BALANCE
  COORDINATION
  STABILITY
}

enum GenerationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum WorkoutStatus {
  GENERATED
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum ExerciseType {
  STRENGTH
  DISTANCE
  TIMED
  TIMED_INTERVALS
  DISTANCE_INTERVALS
  AMRAP
  EMOM
  SUPERSET
}

enum IntervalType {
  TIMED
  DISTANCE
  STRENGTH
}

enum TimeUnit {
  SECONDS
  MINUTES
  HOURS
}

scalar DateTime
scalar JSON

type Query {
  user(id: Int!): User
  users: [User!]!
  benchmark(id: Int!): Benchmark
  benchmarks: [Benchmark!]!
  mesoCycle(id: Int!): MesoCycle
  mesoCycles: [MesoCycle!]!
  workout(id: Int!): Workout
  workouts: [Workout!]!
  exercise(id: String!): Exercise
  exercises: [Exercise!]!
  interval(id: Int!): Interval
  intervals: [Interval!]!
  exerciseSet(id: String!): ExerciseSet
  exerciseSets: [ExerciseSet!]!
  trainingPlan(id: String!): TrainingPlan
  trainingPlans: [TrainingPlan!]!

  wod(id: String!): Wod
  wods: [Wod!]!
}

type Mutation {
  createUser(input: CreateUserInput!): User!
  updateUser(id: Int!, input: UpdateUserInput!): User!
  deleteUser(id: Int!): User!

  createBenchmark(input: CreateBenchmarkInput!): Benchmark!
  updateBenchmark(id: Int!, input: UpdateBenchmarkInput!): Benchmark!
  deleteBenchmark(id: Int!): Benchmark!

  createMesoCycle(input: CreateMesoCycleInput!): MesoCycle!
  updateMesoCycle(id: Int!, input: UpdateMesoCycleInput!): MesoCycle!
  deleteMesoCycle(id: Int!): MesoCycle!

  createWorkout(input: CreateWorkoutInput!): Workout!
  updateWorkout(id: Int!, input: UpdateWorkoutInput!): Workout!
  deleteWorkout(id: Int!): Workout!

  createExercise(input: CreateExerciseInput!): Exercise!
  updateExercise(id: String!, input: UpdateExerciseInput!): Exercise!
  deleteExercise(id: String!): Exercise!

  createInterval(input: CreateIntervalInput!): Interval!
  updateInterval(id: Int!, input: UpdateIntervalInput!): Interval!
  deleteInterval(id: Int!): Interval!

  createExerciseSet(input: CreateExerciseSetInput!): ExerciseSet!
  updateExerciseSet(id: String!, input: UpdateExerciseSetInput!): ExerciseSet!
  deleteExerciseSet(id: String!): ExerciseSet!

  createTrainingPlan(input: CreateTrainingPlanInput!): TrainingPlan!
  updateTrainingPlan(id: String!, input: UpdateTrainingPlanInput!): TrainingPlan!
  deleteTrainingPlan(id: String!): TrainingPlan!

  generateWod(input: CreateWodInput!): Wod!
  updateWod(id: Int!, input: UpdateWodInput!): Wod!
  deleteWod(id: Int!): Wod!
}

input LoadParams {
  weight: Int
  volume: Int
  skill: Int
}

input CreateWodInput {
  description: String
  loadParams: LoadParams
}

input UpdateWodInput {
  name: String
  description: String
}

input CreateUserInput {
  firstName: String
  lastName: String
  email: String!
  age: Int
  gender: Gender
  fitnessLevel: FitnessLevel
  equipment: [FitnessEquipment!]
  goal: String
  weight: WeightInput
  height: HeightInput
}

input UpdateUserInput {
  firstName: String
  lastName: String
  email: String
  age: Int
  gender: Gender
  fitnessLevel: FitnessLevel
  equipment: [FitnessEquipment!]
  goal: String
  weight: WeightInput
  height: HeightInput
}

input CreateBenchmarkInput {
  userId: Int!
  movement: BenchmarkMovement!
  type: BenchmarkType!
  typeValue: BenchmarkTypeValue!
  weight: Float
  reps: Int
  time: Int
  timeUnit: String
  distance: Float
  distanceUnit: String
  weightUnit: WeightUnit
}

input UpdateBenchmarkInput {
  movement: BenchmarkMovement
  type: BenchmarkType
  typeValue: BenchmarkTypeValue
  weight: Float
  reps: Int
  time: Int
  timeUnit: String
  distance: Float
  distanceUnit: String
  weightUnit: WeightUnit
}

input CreateMesoCycleInput {
  userId: Int!
  name: String!
  description: String
  workoutsPerWeek: Int!
  mesocycleLength: Int!
  primaryFocus: Focus!
  secondaryFocus: Focus
  hasDeloadWeek: Boolean
  hasTestingWeek: Boolean
  timePerWorkout: Int!
}

input UpdateMesoCycleInput {
  name: String
  description: String
  workoutsPerWeek: Int
  mesocycleLength: Int
  primaryFocus: Focus
  secondaryFocus: Focus
  hasDeloadWeek: Boolean
  hasTestingWeek: Boolean
  timePerWorkout: Int
  status: GenerationStatus
  error: String
  progress: Float
}

input CreateWorkoutInput {
  name: String!
  description: String
  userId: Int
  trainingPlanId: String
  mesoCycleId: Int
  status: WorkoutStatus
  dateScheduled: DateTime
  order: Int
}

input UpdateWorkoutInput {
  name: String
  description: String
  status: WorkoutStatus
  dateScheduled: DateTime
  dateCompleted: DateTime
  order: Int
}

input CreateExerciseInput {
  name: String!
  description: String!
  order: Int!
  type: ExerciseType!
  rounds: Int
  definition: JSON!
  workoutId: Int!
}

input UpdateExerciseInput {
  name: String
  description: String
  order: Int
  type: ExerciseType
  rounds: Int
  definition: JSON
}

input CreateIntervalInput {
  type: IntervalType!
  time: Int!
  unit: TimeUnit!
  rest: Int!
  restUnit: TimeUnit!
  exerciseId: String!
}

input UpdateIntervalInput {
  type: IntervalType
  time: Int
  unit: TimeUnit
  completed: Boolean
  rest: Int
  restUnit: TimeUnit
}

input CreateExerciseSetInput {
  name: String!
  reps: Int!
  weight: Float!
  unit: WeightUnit!
  rest: Int!
  restUnit: TimeUnit!
  exerciseId: String!
}

input UpdateExerciseSetInput {
  name: String
  reps: Int
  weight: Float
  unit: WeightUnit
  completed: Boolean
  rest: Int
  restUnit: TimeUnit
}

input CreateTrainingPlanInput {
  name: String!
  description: String!
  goal: String!
  threadId: String
  startDate: DateTime!
  endDate: DateTime
  isActive: Boolean
  userId: Int
  creatorId: Int
}

input UpdateTrainingPlanInput {
  name: String
  description: String
  goal: String
  threadId: String
  startDate: DateTime
  endDate: DateTime
  isActive: Boolean
} 
