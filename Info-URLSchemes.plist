    <key>LSApplicationQueriesSchemes</key>
    <array>
        <string>googlechromes</string>
        <string>safari</string>
    </array>
    
    <!-- If your app uses Sign in with Apple -->
    <key>SignInWithApple</key>
    <true/>
</dict>
</plist>
